        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Button Name="btConnect" Content="Connect" HorizontalAlignment="Left" Height="45" Margin="103,27,0,0" VerticalAlignment="Top" Width="106" Click="btConnect_Click"/>
        <Button x:Name="btRead" Content="Read" HorizontalAlignment="Left" Height="45" Margin="322,27,0,0" VerticalAlignment="Top" Width="106" Click="btRead_Click"/>
        <Button x:Name="btWrite" Content="Write" HorizontalAlignment="Left" Height="45" Margin="582,27,0,0" VerticalAlignment="Top" Width="106" Click="btWrite_Click"/>
        <Label Content="Wrte Data:" HorizontalAlignment="Left" Height="33" Margin="38,238,0,0" VerticalAlignment="Top" Width="78"/>
        <TextBox x:Name="tbWrite" Margin="2,0,1,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Center" Height="38"/>
        <Label Content="Read Data:" HorizontalAlignment="Left" Margin="22,331,0,0" VerticalAlignment="Top" Width="84"/>
        <Label Name="lReadData" Content="1" HorizontalAlignment="Center" Height="31" Margin="0,377,0,0" VerticalAlignment="Top" Width="796"/>
        <Rectangle HorizontalAlignment="Right" Height="69" Margin="0,115,4,0" Stroke="Black" VerticalAlignment="Top" Width="792"/>
        <Label Content="串口" HorizontalAlignment="Left" Margin="18,131,0,0" VerticalAlignment="Top"/>
        <Button x:Name="btConnectSerial" Content="Connect" HorizontalAlignment="Left" Height="45" Margin="109,126,0,0" VerticalAlignment="Top" Width="106" Click="btConnectSerial_Click"/>
        <Button x:Name="btReadSerial" Content="Read" HorizontalAlignment="Left" Height="45" Margin="328,126,0,0" VerticalAlignment="Top" Width="106" Click="btReadSerial_Click"/>
        <Button x:Name="btWriteSerial" Content="Write" HorizontalAlignment="Left" Height="45" Margin="588,126,0,0" VerticalAlignment="Top" Width="106" Click="btWriteSerial_Click"/>
        <Rectangle HorizontalAlignment="Center" Height="69" Margin="0,19,0,0" Stroke="Black" VerticalAlignment="Top" Width="792"/>
        <Label Content="网口" HorizontalAlignment="Left" Margin="18,35,0,0" VerticalAlignment="Top"/>

    </Grid>
</Window>
